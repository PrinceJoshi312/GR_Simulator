+import { useState } from "react";
+
+import { createRun, pauseRun, resetRun, type RunPayload } from "../../services/runService";
+
+export function Workspace() {
+  const [run, setRun] = useState<RunPayload | null>(null);
+  const [state, setState] = useState("idle");
+
+  async function handleRun() {
+    setState("loading");
+    try {
+      const started = await createRun();
+      setRun(started);
+      setState(started.state);
+    } catch {
+      setState("error");
+    }
+  }
+
+  async function handlePause() {
+    if (!run) return;
+    const paused = await pauseRun(run.run_id);
+    setRun(paused);
+    setState(paused.state);
+  }
+
+  async function handleReset() {
+    if (!run) return;
+    const reset = await resetRun(run.run_id);
+    setRun(reset);
+    setState(reset.state);
+  }
+
+  return (
+    <main>
+      <h1>GRsimulator Workspace</h1>
+      <section aria-label="simulation-controls">
+        <button onClick={handleRun}>Run</button>
+        <button onClick={handlePause} disabled={!run}>
+          Pause
+        </button>
+        <button onClick={handleReset} disabled={!run}>
+          Reset
+        </button>
+      </section>
+      <section aria-label="run-status">
+        <p>State: {state}</p>
+        {run ? (
+          <ul>
+            <li>Scenario: {run.scenario_id}</li>
+            <li>Seed: {run.seed}</li>
+            <li>G: {run.g}</li>
+            <li>Central Mass: {run.central_mass}</li>
+            <li>Engine Version: {run.engine_version}</li>
+          </ul>
+        ) : (
+          <p>No run started.</p>
+        )}
+      </section>
+    </main>
+  );
+}
