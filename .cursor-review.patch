+import { fireEvent, render, screen, waitFor } from "@testing-library/react";
+import { describe, expect, it, vi } from "vitest";
+
+import { Workspace } from "../src/features/workspace/Workspace";
+
+describe("Workspace", () => {
+  it("shows lifecycle controls and updates state from run metadata", async () => {
+    const fetchMock = vi.fn()
+      .mockResolvedValueOnce({
+        json: async () => ({
+          data: {
+            run_id: "run-1",
+            state: "running",
+            scenario_id: "default-schwarzschild",
+            seed: 42,
+            g: 6.6743e-11,
+            central_mass: 1.98847e30,
+            engine_version: "0.1.0",
+          },
+        }),
+      })
+      .mockResolvedValueOnce({
+        json: async () => ({ data: { run_id: "run-1", state: "paused", scenario_id: "default-schwarzschild", seed: 42, g: 6.6743e-11, central_mass: 1.98847e30, engine_version: "0.1.0" } }),
+      })
+      .mockResolvedValueOnce({
+        json: async () => ({ data: { run_id: "run-1", state: "idle", scenario_id: "default-schwarzschild", seed: 42, g: 6.6743e-11, central_mass: 1.98847e30, engine_version: "0.1.0" } }),
+      });
+    vi.stubGlobal("fetch", fetchMock);
+
+    render(<Workspace />);
+    fireEvent.click(screen.getByText("Run"));
+    await waitFor(() => expect(screen.getByText("State: running")).toBeTruthy());
+    expect(screen.getByText("Seed: 42")).toBeTruthy();
+
+    fireEvent.click(screen.getByText("Pause"));
+    await waitFor(() => expect(screen.getByText("State: paused")).toBeTruthy());
+
+    fireEvent.click(screen.getByText("Reset"));
+    await waitFor(() => expect(screen.getByText("State: idle")).toBeTruthy());
+  });
+});
