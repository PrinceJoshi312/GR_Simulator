@@ -0,0 +1,12 @@
+def equatorial_christoffel(metric: dict[str, float]) -> dict[str, float]:
+    r = metric["r"]
+    rs = metric["schwarzschild_radius"]
+    f = 1.0 - (rs / r)
+
+    return {
+        "gamma_t_tr": rs / (2.0 * r * r * f),
+        "gamma_r_tt": (rs * f) / (2.0 * r * r),
+        "gamma_r_rr": -rs / (2.0 * r * r * f),
+        "gamma_r_phiphi": -(r - rs),
+        "gamma_phi_rphi": 1.0 / r,
+    }
